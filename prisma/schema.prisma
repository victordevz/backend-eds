generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  passwordHash     String
  balance          Float            @default(0)
  createdAt        DateTime         @default(now())
  deposits         Deposit[]
  storyViews       StoryView[]
  supportSessions  SupportSession[]
}

model Deposit {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  amount      Float
  status      DepositStatus @default(PENDING)
  pixCode     String
  createdAt   DateTime      @default(now())
  completedAt DateTime?
}

enum DepositStatus {
  PENDING
  COMPLETED
}

model Game {
  id        String     @id @default(uuid())
  homeTeam  String
  awayTeam  String
  oddsHome  Float
  oddsDraw  Float
  oddsAway  Float
  status    GameStatus @default(OPEN)
  startsAt  DateTime
  createdAt DateTime   @default(now())
}

enum GameStatus {
  OPEN
  IN_PROGRESS
  FINISHED
  CANCELLED
}

model CasinoGame {
  id         String       @id @default(uuid())
  title      String
  provider   String
  category   GameCategory
  sections   String[]
  badge      String?
  multiplier String?
  accent     String?
  thumbnail  String?
  gameUrl    String
  imageUrl   String?
  active     Boolean      @default(true)
  createdAt  DateTime     @default(now())
}

enum GameCategory {
  SLOTS
  CRASH
  ROULETTE
  BLACKJACK
}

model Story {
  id           String      @id @default(uuid())
  title        String
  videoUrl     String
  thumbnailUrl String?
  order        Int         @default(0)
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now())
  views        StoryView[]
}

model StoryView {
  id       String   @id @default(uuid())
  storyId  String
  story    Story    @relation(fields: [storyId], references: [id])
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  viewedAt DateTime @default(now())

  @@unique([storyId, userId])
}

model SupportSession {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  createdAt DateTime         @default(now())
  messages  SupportMessage[]
}

model SupportMessage {
  id        String          @id @default(uuid())
  sessionId String
  session   SupportSession  @relation(fields: [sessionId], references: [id])
  role      MessageRole
  content   String
  createdAt DateTime        @default(now())
}

enum MessageRole {
  USER
  ASSISTANT
}
