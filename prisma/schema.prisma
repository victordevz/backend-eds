generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  balance      Float     @default(0)
  createdAt    DateTime  @default(now())
  deposits     Deposit[]
}

model Deposit {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  amount      Float
  status      DepositStatus @default(PENDING)
  pixCode     String
  createdAt   DateTime      @default(now())
  completedAt DateTime?
}

enum DepositStatus {
  PENDING
  COMPLETED
}

model Game {
  id        String     @id @default(uuid())
  homeTeam  String
  awayTeam  String
  oddsHome  Float
  oddsDraw  Float
  oddsAway  Float
  status    GameStatus @default(OPEN)
  startsAt  DateTime
  createdAt DateTime   @default(now())
}

enum GameStatus {
  OPEN
  IN_PROGRESS
  FINISHED
  CANCELLED
}

